{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "baccaratmaster",
  "main": "worker.ts",
  "compatibility_date": "2026-04-17",
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "baccarat-master-db",
      "database_id": "1ec6974a-786d-44b3-bb06-dcdd738924ed"
    }
  ]
}
